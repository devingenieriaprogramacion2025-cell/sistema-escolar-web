@model SistemaEscolarWeb.ViewModels.GestionTecnologiaViewModel
@{
    ViewData["Title"] = "Tecnologia";
    var busqueda = ViewBag.Busqueda as string;
    var puedeEditar = User.HasPermission("tecnologia.gestionar", "Editar tecnología", "Editar tecnologÃ­a");
    var puedeSolicitarBaja = User.HasPermission("bajas.solicitar", "Solicitar bajas");
}

@functions {
    string BadgeClass(string estado) => estado switch
    {
        "Disponible" => "text-bg-success",
        "Asignado" => "text-bg-primary",
        "En ReparaciÃ³n" => "text-bg-warning",
        "Dado de Baja" => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}

<div class="page-heading">
    <div>
        <h2>Tecnologia</h2>
        <p>Registre y mantenga los activos tecnologicos segun modelo, entrada y tipo.</p>
    </div>
    @if (Model.TienePaginaAnterior)
    {
        <a asp-action="Index"
           asp-route-busqueda="@Model.Busqueda"
           asp-route-ordenar="@Model.Ordenar"
           asp-route-direccion="@Model.Direccion"
           asp-route-pagina="@(Model.PaginaActual - 1)"
           class="btn btn-outline-secondary">
            Volver
        </a>
    }
</div>

<div class="content-card mb-3">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-8">
            <label class="form-label">Buscar</label>
            <input name="busqueda" value="@busqueda" class="form-control" placeholder="Codigo, marca, modelo o tipo..." />
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i> Buscar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>
</div>


<div class="content-card">
    @if (!Model.Equipos.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-pc-display"></i>
            <h3>No existen equipos registrados</h3>
            <p>No se encontraron activos tecnologicos para mostrar.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="codigo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "codigo")">Codigo <i class="bi @ListadoVista.IconoOrden(Model, "codigo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="marca" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "marca")">Marca <i class="bi @ListadoVista.IconoOrden(Model, "marca")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="modelo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "modelo")">Modelo <i class="bi @ListadoVista.IconoOrden(Model, "modelo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="tipo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "tipo")">Tipo <i class="bi @ListadoVista.IconoOrden(Model, "tipo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="descripcion" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "descripcion")">Descripcion <i class="bi @ListadoVista.IconoOrden(Model, "descripcion")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="estado" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "estado")">Estado <i class="bi @ListadoVista.IconoOrden(Model, "estado")"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Equipos)
                {
                    <tr>
                        <td><strong>@item.CodigoInventario</strong></td>
                        <td>@item.Marca</td>
                        <td>@item.Modelo</td>
                        <td>@item.TipoTecnologia</td>
                        <td>@item.Descripcion</td>
                        <td><span class="badge @BadgeClass(item.EstadoOperativo)">@item.EstadoOperativo</span></td>
                        <td class="text-end actions-cell">
                            <a asp-action="Detalle" asp-route-id="@item.IdTecnologia" class="btn btn-sm btn-outline-primary">Ver</a>
                            @if ((puedeEditar || puedeSolicitarBaja) && item.PuedeEditar)
                            {
                                @if (puedeEditar)
                                {
                                    <a asp-controller="EntradasTecnologia" asp-action="Editar" asp-route-id="@item.IdTecnologia" class="btn btn-sm btn-outline-secondary">Editar</a>
                                }
                                @if (puedeSolicitarBaja)
                                {
                                    <a asp-controller="Bajas" asp-action="Crear" asp-route-idTecnologia="@item.IdTecnologia" class="btn btn-sm btn-outline-danger">Dar de baja</a>
                                }
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Paginacion" model="Model" />
    }
</div>
