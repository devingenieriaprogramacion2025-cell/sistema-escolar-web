@model SistemaEscolarWeb.ViewModels.CrearEquipoViewModel
@{
    ViewData["Title"] = "Nuevo equipo";
}

<div class="page-heading">
    <div>
        <h2>Nuevo equipo</h2>
        <p>Registre la entrada completa del activo tecnologico institucional.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="content-card">
    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <h3>Datos del equipo</h3>
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <label asp-for="SkuCodigoInventario" class="form-label"></label>
                <input asp-for="SkuCodigoInventario" class="form-control" autocomplete="off" />
                <span asp-validation-for="SkuCodigoInventario" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Marca" class="form-label"></label>
                <input asp-for="Marca" id="Marca" class="form-control" list="marcasCatalogo" autocomplete="off" />
                <span asp-validation-for="Marca" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Modelo" class="form-label"></label>
                <input asp-for="Modelo" id="Modelo" class="form-control" list="modelosCatalogo" autocomplete="off" />
                <span asp-validation-for="Modelo" class="text-danger small"></span>
            </div>
        </div>

        <h3 class="mt-4">Entrada</h3>
        <div class="row g-3 mt-1">
            <div class="col-md-3">
                <label asp-for="FechaEntrada" class="form-label"></label>
                <input asp-for="FechaEntrada" type="date" class="form-control" />
                <span asp-validation-for="FechaEntrada" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Proveedor" class="form-label"></label>
                <input asp-for="Proveedor" class="form-control" autocomplete="off" />
                <span asp-validation-for="Proveedor" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Cantidad" class="form-label"></label>
                <input asp-for="Cantidad" type="number" min="1" class="form-control" />
                <span asp-validation-for="Cantidad" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="NumeroFactura" class="form-label"></label>
                <input asp-for="NumeroFactura" class="form-control" />
                <span asp-validation-for="NumeroFactura" class="text-danger small"></span>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input asp-for="Estado" class="form-check-input" />
                    <label asp-for="Estado" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <h3 class="mt-4">Tipo de tecnologia</h3>
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <label asp-for="TipoTecnologia" class="form-label"></label>
                <input asp-for="TipoTecnologia" class="form-control" list="tiposTecnologiaCatalogo" autocomplete="off" />
                <span asp-validation-for="TipoTecnologia" class="text-danger small"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_CatalogosTecnologia" />
}
