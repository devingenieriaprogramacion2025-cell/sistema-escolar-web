@model SistemaEscolarWeb.ViewModels.GestionEntradasTecnologiaViewModel
@{
    ViewData["Title"] = "Entradas tecnologia";
    var editando = ViewData["EditandoEntradaTecnologia"] as bool? == true;
    var accionFormulario = editando ? "Editar" : "Crear";
}

<div class="page-heading">
    <div>
        <h2>Entradas tecnologia</h2>
        <p>Registre proveedor, fecha, cantidad y factura de la entrada tecnologica.</p>
    </div>
</div>

<div class="content-card mb-4">
    <h3 class="h5 mb-3">@(editando ? "Editar entrada tecnologia" : "Nueva entrada tecnologia")</h3>
    <form asp-action="@accionFormulario" method="post" class="row g-3 align-items-end">
        @Html.AntiForgeryToken()
        @if (editando)
        {
            <input type="hidden" name="IdEntradaTecnologia" value="@Model.Formulario.IdEntradaTecnologia" />
        }
        <div class="col-md-3">
            <label asp-for="Formulario.IdProveedor" class="form-label"></label>
            <div class="input-group">
                <select asp-for="Formulario.IdProveedor" asp-items="Model.Formulario.Proveedores" id="IdProveedor" name="IdProveedor" class="form-select">
                    <option value="">Seleccione un proveedor</option>
                </select>
                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#proveedorRapidoModal">
                    <i class="bi bi-plus-lg"></i>
                </button>
            </div>
            <span asp-validation-for="Formulario.IdProveedor" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.Marca" class="form-label"></label>
            <input asp-for="Formulario.Marca" name="Marca" id="Marca" class="form-control" list="marcasCatalogo" autocomplete="off" />
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.Modelo" class="form-label"></label>
            <input asp-for="Formulario.Modelo" name="Modelo" id="Modelo" class="form-control" list="modelosCatalogo" autocomplete="off" />
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.TipoTecnologia" class="form-label"></label>
            <input asp-for="Formulario.TipoTecnologia" name="TipoTecnologia" class="form-control" list="tiposTecnologiaCatalogo" autocomplete="off" />
        </div>
        <div class="col-md-6">
            <label asp-for="Formulario.Descripcion" class="form-label"></label>
            <input asp-for="Formulario.Descripcion" name="Descripcion" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.PrefijoSku" class="form-label"></label>
            <input asp-for="Formulario.PrefijoSku" name="PrefijoSku" class="form-control" autocomplete="off" />
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.FechaEntrada" class="form-label"></label>
            <input asp-for="Formulario.FechaEntrada" name="FechaEntrada" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Formulario.Cantidad" class="form-label"></label>
            <input asp-for="Formulario.Cantidad" name="Cantidad" type="number" min="1" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Formulario.NumeroFactura" class="form-label"></label>
            <input asp-for="Formulario.NumeroFactura" name="NumeroFactura" class="form-control" />
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> @(editando ? "Guardar cambios" : "Guardar entrada")</button>
            @if (editando)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            }
        </div>
    </form>
</div>

<div class="content-card">
    <h3 class="h5 mb-3">Historial de entradas tecnologia</h3>
    @if (!Model.Entradas.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-box-arrow-in-down"></i>
            <h3>No hay entradas registradas</h3>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th><a class="table-sort-link" asp-route-ordenar="proveedor" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "proveedor")">Proveedor <i class="bi @ListadoVista.IconoOrden(Model, "proveedor")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="marca" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "marca")">Marca <i class="bi @ListadoVista.IconoOrden(Model, "marca")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="modelo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "modelo")">Modelo <i class="bi @ListadoVista.IconoOrden(Model, "modelo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="tipo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "tipo")">Tipo <i class="bi @ListadoVista.IconoOrden(Model, "tipo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="sku" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "sku")">SKU generados <i class="bi @ListadoVista.IconoOrden(Model, "sku")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="fecha" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "fecha")">Fecha entrada <i class="bi @ListadoVista.IconoOrden(Model, "fecha")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="cantidad" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "cantidad")">Cantidad <i class="bi @ListadoVista.IconoOrden(Model, "cantidad")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="factura" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "factura")">Numero factura <i class="bi @ListadoVista.IconoOrden(Model, "factura")"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Entradas)
                {
                    <tr>
                        <td><strong>@item.Proveedor</strong></td>
                        <td>@item.Marca</td>
                        <td>@item.Modelo</td>
                        <td>@item.TipoTecnologia</td>
                        <td>@item.SkuGenerados</td>
                        <td>@item.FechaEntrada.ToString("dd/MM/yyyy")</td>
                        <td>@item.Cantidad</td>
                        <td>@item.NumeroFactura</td>
                        <td class="text-end">
                            <a asp-action="Editar" asp-route-id="@item.IdEntradaTecnologia" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil-square me-1"></i> Editar
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Paginacion" model="Model" />
    }
</div>
<partial name="_ProveedorRapidoModal" />

@section Scripts {
    <partial name="~/Views/Tecnologia/_CatalogosTecnologia.cshtml" />
    <script src="~/js/personal-form.js" asp-append-version="true"></script>
}
