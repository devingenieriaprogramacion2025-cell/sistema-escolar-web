@model SistemaEscolarWeb.ViewModels.CrearAsignacionViewModel
@{
    ViewData["Title"] = "Nueva asignacion";
}

<div class="page-heading">
    <div>
        <h2>Nueva asignacion</h2>
        <p>Asigne una tecnologia disponible a una persona y dependencia institucional.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</div>

<div class="content-card">
    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <h5 class="mb-3">Seleccion</h5>
        <div class="row g-3">
            <div class="col-md-12">
                <label asp-for="IdTecnologia" class="form-label">Equipo / tecnologia, marca y modelo</label>
                <select asp-for="IdTecnologia" asp-items="Model.EquiposDisponibles" class="form-select">
                    <option value="">Seleccione tecnologia por tipo, marca, modelo y codigo</option>
                </select>
                <div class="form-text">Solo se muestran tecnologias disponibles para asignacion.</div>
                <span asp-validation-for="IdTecnologia" class="text-danger small"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="TipoDestinatario" class="form-label d-block"></label>
                <div class="d-flex flex-wrap gap-4">
                    <div class="form-check">
                        <input asp-for="TipoDestinatario" class="form-check-input destinatario-radio" type="radio" id="TipoDestinatarioPersona" value="Persona" />
                        <label class="form-check-label" for="TipoDestinatarioPersona">Persona</label>
                    </div>
                    <div class="form-check">
                        <input asp-for="TipoDestinatario" class="form-check-input destinatario-radio" type="radio" id="TipoDestinatarioDependencia" value="Dependencia" />
                        <label class="form-check-label" for="TipoDestinatarioDependencia">Dependencia</label>
                    </div>
                </div>
                <span asp-validation-for="TipoDestinatario" class="text-danger small"></span>
            </div>

            <div class="col-md-6 destinatario-panel" id="personaPanel">
                <label asp-for="RutPersonal" class="form-label"></label>
                <select asp-for="RutPersonal" asp-items="Model.PersonalDisponible" class="form-select">
                    <option value="">Seleccione persona</option>
                </select>
                <span asp-validation-for="RutPersonal" class="text-danger small"></span>
            </div>
            <div class="col-md-6 destinatario-panel" id="dependenciaPanel">
                <label asp-for="IdDependencia" class="form-label"></label>
                <select asp-for="IdDependencia" asp-items="Model.Dependencias" class="form-select">
                    <option value="">Seleccione dependencia</option>
                </select>
                <span asp-validation-for="IdDependencia" class="text-danger small"></span>
            </div>
        </div>

        <hr />
        <h5 class="mb-3">Informacion asignacion</h5>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="TipoAsignacion" class="form-label"></label>
                <input asp-for="TipoAsignacion" class="form-control" />
                <span asp-validation-for="TipoAsignacion" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Observacion" class="form-label"></label>
                <input asp-for="Observacion" class="form-control" placeholder="Opcional" />
                <span asp-validation-for="Observacion" class="text-danger small"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const personaRadio = document.getElementById('TipoDestinatarioPersona');
            const dependenciaRadio = document.getElementById('TipoDestinatarioDependencia');
            const personaPanel = document.getElementById('personaPanel');
            const dependenciaPanel = document.getElementById('dependenciaPanel');
            const personaSelect = document.getElementById('RutPersonal');
            const dependenciaSelect = document.getElementById('IdDependencia');

            function actualizarDestinatario() {
                const esPersona = personaRadio.checked;

                personaPanel.classList.toggle('d-none', !esPersona);
                dependenciaPanel.classList.toggle('d-none', esPersona);
                personaSelect.disabled = !esPersona;
                dependenciaSelect.disabled = esPersona;

                if (esPersona) {
                    dependenciaSelect.value = '';
                } else {
                    personaSelect.value = '';
                }
            }

            document.querySelectorAll('.destinatario-radio').forEach(radio => {
                radio.addEventListener('change', actualizarDestinatario);
            });

            if (!personaRadio.checked && !dependenciaRadio.checked) {
                personaRadio.checked = true;
            }

            actualizarDestinatario();
        })();
    </script>
}
