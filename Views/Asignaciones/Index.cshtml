@model SistemaEscolarWeb.ViewModels.ListadoPaginadoViewModel<SistemaEscolarWeb.DTOs.AsignacionDto>
@{
    ViewData["Title"] = "Asignaciones";
    var busqueda = ViewBag.Busqueda as string;
    var puedeGestionar = User.HasPermission("tecnologia.asignar", "Crear asignaciones");
}

@functions {
    string BadgeClass(string estado) => estado switch
    {
        "Activa" => "text-bg-primary",
        "Vigente" => "text-bg-primary",
        "Finalizada" => "text-bg-success",
        "Dado de Baja" => "text-bg-danger",
        _ => "text-bg-secondary"
    };
}

<div class="page-heading">
    <div>
        <h2>@ViewData["Title"]</h2>
        <p>Consulte y gestione las salidas de equipamiento tecnologico institucional.</p>
    </div>
    @if (puedeGestionar)
    {
        <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Nueva asignacion</a>
    }
</div>

<div class="content-card mb-3">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-8">
            <label class="form-label">Buscar</label>
            <input name="busqueda" value="@busqueda" class="form-control" placeholder="Equipo, marca, modelo, persona, dependencia o estado..." />
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i> Buscar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>
</div>

<div class="content-card">
    @if (!Model.Items.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-clipboard-check"></i>
            <h3>No existen asignaciones registradas</h3>
            <p>No se encontraron asignaciones para mostrar.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="equipo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "equipo")">Equipo <i class="bi @ListadoVista.IconoOrden(Model, "equipo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="marca" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "marca")">Marca <i class="bi @ListadoVista.IconoOrden(Model, "marca")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="modelo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "modelo")">Modelo <i class="bi @ListadoVista.IconoOrden(Model, "modelo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="tipo-destinatario" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "tipo-destinatario")">Tipo destinatario <i class="bi @ListadoVista.IconoOrden(Model, "tipo-destinatario")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="destinatario" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "destinatario")">Asignado a <i class="bi @ListadoVista.IconoOrden(Model, "destinatario")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="fecha" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "fecha")">Fecha asignacion <i class="bi @ListadoVista.IconoOrden(Model, "fecha")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="estado" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "estado")">Estado <i class="bi @ListadoVista.IconoOrden(Model, "estado")"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <strong>@item.CodigoEquipo</strong>
                            <div class="small text-muted">@item.TipoTecnologia</div>
                        </td>
                        <td>@item.MarcaEquipo</td>
                        <td>@item.ModeloEquipo</td>
                        <td>@item.TipoDestinatario</td>
                        <td>@item.AsignadoA</td>
                        <td>@item.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                        <td><span class="badge @BadgeClass(item.EstadoAsignacion)">@item.EstadoAsignacion</span></td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-id="@item.IdAsignaciones" class="btn btn-sm btn-outline-primary">Ver</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Paginacion" model="Model" />
    }
</div>
