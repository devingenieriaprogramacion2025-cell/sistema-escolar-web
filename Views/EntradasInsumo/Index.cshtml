@model SistemaEscolarWeb.ViewModels.ListadoPaginadoViewModel<SistemaEscolarWeb.DTOs.EntradaInsumoDto>
@{
    ViewData["Title"] = "Entradas de insumos";
    var puedeGestionar = User.HasPermission("insumos.gestionar", "Crear insumos");
}

<div class="page-heading">
    <div>
        <h2>Entradas de insumos</h2>
        <p>Historial de ingresos de stock por insumo.</p>
    </div>
    @if (puedeGestionar)
    {
        <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nueva entrada</a>
    }
</div>

<div class="content-card">
    @if (!Model.Items.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-box-arrow-in-down"></i>
            <h3>No hay entradas registradas</h3>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th><a class="table-sort-link" asp-route-ordenar="insumo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "insumo")">Insumo <i class="bi @ListadoVista.IconoOrden(Model, "insumo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="proveedor" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "proveedor")">Proveedor <i class="bi @ListadoVista.IconoOrden(Model, "proveedor")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="factura" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "factura")">Factura <i class="bi @ListadoVista.IconoOrden(Model, "factura")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="fecha" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "fecha")">Fecha entrega <i class="bi @ListadoVista.IconoOrden(Model, "fecha")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="cantidad" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "cantidad")">Cantidad <i class="bi @ListadoVista.IconoOrden(Model, "cantidad")"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><strong>@item.Insumo</strong></td>
                        <td>@item.Proveedor</td>
                        <td>@item.NumeroFactura</td>
                        <td>@item.FechaEntrega.ToString("dd/MM/yyyy")</td>
                        <td>@item.Cantidad</td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-id="@item.IdEntradaInsumo" class="btn btn-outline-secondary btn-sm">Ver</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Paginacion" model="Model" />
    }
</div>
