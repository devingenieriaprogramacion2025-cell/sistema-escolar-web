@model SistemaEscolarWeb.DTOs.EntradaInsumoDto
@{
    ViewData["Title"] = "Detalle entrada de insumo";
}

<div class="page-heading">
    <div>
        <h2>Detalle entrada</h2>
        <p>Movimiento de ingreso de stock.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="content-card">
    <dl class="row mb-0">
        <dt class="col-md-3">Insumo</dt>
        <dd class="col-md-9">@Model.Insumo</dd>
        <dt class="col-md-3">Proveedor</dt>
        <dd class="col-md-9">@Model.Proveedor</dd>
        <dt class="col-md-3">Factura</dt>
        <dd class="col-md-9">@Model.NumeroFactura</dd>
        <dt class="col-md-3">Fecha entrega</dt>
        <dd class="col-md-9">@Model.FechaEntrega.ToString("dd/MM/yyyy")</dd>
        <dt class="col-md-3">Cantidad</dt>
        <dd class="col-md-9">@Model.Cantidad</dd>
    </dl>
</div>
