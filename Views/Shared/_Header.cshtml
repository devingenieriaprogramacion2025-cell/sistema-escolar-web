<header class="app-header">
    <div>
        <h1 class="h5 mb-0">Sistema Escolar Web</h1>
        <small class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</small>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="text-end d-none d-md-block">
            <div class="fw-semibold">@User.Identity?.Name</div>
            <small class="text-muted">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-primary btn-sm" type="submit">
                <i class="bi bi-box-arrow-right"></i> Cerrar sesion
            </button>
        </form>
    </div>
</header>
