@model SistemaEscolarWeb.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
}
<div class="page-heading">
    <h2>Restablecer contraseña</h2>
    <p>Genere una contraseña temporal para el usuario seleccionado.</p>
</div>
<div class="content-card">
    <div class="mb-4 p-3 rounded bg-light">
        <strong>@Model.NombreCompleto</strong><br />
        <span>@Model.Correo</span>
    </div>
    <form asp-action="ResetPassword" method="post">
        <input asp-for="IdUsuario" type="hidden" />
        <input asp-for="NombreCompleto" type="hidden" />
        <input asp-for="Correo" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6"><label asp-for="PasswordTemporal" class="form-label"></label><input asp-for="PasswordTemporal" class="form-control" /><span asp-validation-for="PasswordTemporal" class="text-danger"></span></div>
        </div>
        <div class="mt-4 d-flex gap-2"><button class="btn btn-primary" type="submit">Restablecer</button><a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
