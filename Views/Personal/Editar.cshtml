@model SistemaEscolarWeb.ViewModels.PersonalFormViewModel
@{
    ViewData["Title"] = "Editar Personal";
}
<div class="page-heading">
    <h2>Editar personal</h2>
    <p>Actualice la información institucional registrada.</p>
</div>
<div class="content-card">
    <form asp-action="Editar" method="post">
        <input asp-for="RutPersonal" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <h5>Información general</h5>
        <div class="row g-3">
            <div class="col-md-4"><label class="form-label">RUT</label><input value="@Model.RutPersonal" class="form-control" disabled /></div>
            <div class="col-md-4"><label asp-for="Nombre" class="form-label"></label><input asp-for="Nombre" class="form-control" /><span asp-validation-for="Nombre" class="text-danger"></span></div>
            <div class="col-md-4"><label asp-for="Apellido" class="form-label"></label><input asp-for="Apellido" class="form-control" /><span asp-validation-for="Apellido" class="text-danger"></span></div>
            <div class="col-md-6"><label asp-for="Correo" class="form-label"></label><input asp-for="Correo" class="form-control" /><span asp-validation-for="Correo" class="text-danger"></span></div>
            <div class="col-md-3"><label asp-for="Telefono" class="form-label"></label><input asp-for="Telefono" type="tel" class="form-control" maxlength="12" inputmode="tel" autocomplete="tel" placeholder="+56935315783" data-telefono-chileno /><span asp-validation-for="Telefono" class="text-danger"></span></div>
            <div class="col-md-3"><label asp-for="Cargo" class="form-label"></label><input asp-for="Cargo" class="form-control" /></div>
            <div class="col-md-6"><label asp-for="IdRol" class="form-label"></label><select asp-for="IdRol" asp-items="Model.Roles" class="form-select"></select><span asp-validation-for="IdRol" class="text-danger"></span></div>
            <div class="col-md-6 d-flex align-items-end"><div class="form-check"><input asp-for="Activo" class="form-check-input" /><label asp-for="Activo" class="form-check-label">Activo</label></div></div>
        </div>
        <div class="mt-4 d-flex gap-2"><button class="btn btn-primary" type="submit">Guardar cambios</button><a asp-action="Detalle" asp-route-id="@Model.RutPersonal" class="btn btn-outline-secondary">Cancelar</a></div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/personal-form.js" asp-append-version="true"></script>
}
