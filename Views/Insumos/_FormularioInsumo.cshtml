@model SistemaEscolarWeb.Models.Insumo
@{
    var tipos = ViewBag.TiposInsumo as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? [];
    var esEdicion = Model.IdInsumo > 0;
}

<div class="content-card">
    <form asp-action="@(esEdicion ? "Editar" : "Crear")" method="post">
        @Html.AntiForgeryToken()
        @if (esEdicion)
        {
            <input asp-for="IdInsumo" type="hidden" />
        }
        <input asp-for="StockMinimo" type="hidden" />
        @if (!esEdicion)
        {
            <input asp-for="StockActual" type="hidden" value="0" />
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="NombreInsumo" class="form-label">Nombre insumo</label>
                <input asp-for="NombreInsumo" class="form-control" maxlength="120" />
                <span asp-validation-for="NombreInsumo" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="IdTipoInsumo" class="form-label">Tipo insumo</label>
                <select asp-for="IdTipoInsumo" asp-items="tipos" class="form-select">
                    <option value="">Seleccione un tipo</option>
                </select>
                <span asp-validation-for="IdTipoInsumo" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="UnidadMedida" class="form-label">Unidad de medida</label>
                <input asp-for="UnidadMedida" class="form-control" maxlength="40" />
                <span asp-validation-for="UnidadMedida" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Toxicidad" class="form-label">Toxicidad</label>
                <select asp-for="Toxicidad" class="form-select">
                    <option value="No toxico">No toxico</option>
                    <option value="Baja">Baja</option>
                    <option value="Media">Media</option>
                    <option value="Alta">Alta</option>
                </select>
                <span asp-validation-for="Toxicidad" class="text-danger small"></span>
            </div>
            @if (esEdicion)
            {
                <div class="col-md-6">
                    <label asp-for="StockActual" class="form-label">Stock actual</label>
                    <input asp-for="StockActual" type="number" min="0" max="100000" class="form-control" />
                    <span asp-validation-for="StockActual" class="text-danger small"></span>
                </div>
            }
            <div class="col-md-6">
                <label asp-for="Estado" class="form-label">Estado</label>
                <select asp-for="Estado" class="form-select">
                    <option value="true">Activo</option>
                    <option value="false">Inactivo</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="DescripcionInsumo" class="form-label">Descripcion</label>
                <textarea asp-for="DescripcionInsumo" class="form-control" maxlength="250" rows="3"></textarea>
                <span asp-validation-for="DescripcionInsumo" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
