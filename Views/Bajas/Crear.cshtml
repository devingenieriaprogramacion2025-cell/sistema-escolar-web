@model SistemaEscolarWeb.ViewModels.CrearBajaViewModel
@{
    ViewData["Title"] = "Nueva baja";
}

<div class="page-heading">
    <div>
        <h2>Nueva baja</h2>
        <p>Registre una solicitud de salida definitiva para aprobacion.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="content-card">
    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="IdTecnologia" class="form-label"></label>
                <select asp-for="IdTecnologia" asp-items="Model.EquiposDisponibles" class="form-select">
                    <option value="">Seleccione equipo</option>
                </select>
                <span asp-validation-for="IdTecnologia" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="IdMotivo" class="form-label"></label>
                <select asp-for="IdMotivo" asp-items="Model.Motivos" class="form-select"></select>
                <span asp-validation-for="IdMotivo" class="text-danger small"></span>
            </div>
            <div class="col-12">
                <label asp-for="Observacion" class="form-label"></label>
                <textarea asp-for="Observacion" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Observacion" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-save me-1"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
