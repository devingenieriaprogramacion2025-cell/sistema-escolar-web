@model SistemaEscolarWeb.ViewModels.PermisosRolIndexViewModel
@{
    ViewData["Title"] = "Permisos por rol";
}

<div class="page-heading">
    <div>
        <h2>Permisos por rol</h2>
        <p>Seleccione un rol para administrar sus permisos del sistema.</p>
    </div>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Nuevo rol
    </a>
</div>

<div class="content-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th><a class="table-sort-link" asp-route-ordenar="rol" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "rol")">Rol <i class="bi @ListadoVista.IconoOrden(Model, "rol")"></i></a></th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var rol in Model.Roles)
            {
                <tr>
                    <td><strong>@rol.NombreRol</strong></td>
                    <td class="text-end">
                        <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                            <a asp-action="Administrar" asp-route-id="@rol.IdRol" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-ui-checks me-1"></i> Administrar permisos
                            </a>
                            <a asp-action="Editar" asp-route-id="@rol.IdRol" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-pencil-square me-1"></i> Modificar
                            </a>
                            <a asp-action="Eliminar" asp-route-id="@rol.IdRol" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash me-1"></i> Eliminar
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Paginacion" model="Model" />
</div>
