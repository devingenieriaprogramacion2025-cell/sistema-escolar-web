@model SistemaEscolarWeb.ViewModels.ReporteEjecutivoViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Reporte Ejecutivo";
    var tecnologiasJson = JsonSerializer.Serialize(Model.TecnologiasPorEstado);
    var impresionesJson = JsonSerializer.Serialize(Model.ImpresionesPorEstado);
}

<div class="page-heading">
    <div>
        <h2>Reporte Ejecutivo</h2>
        <p>Resumen institucional para lectura gerencial.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportarPdf" asp-route-reporte="Ejecutivo" class="btn btn-outline-danger btn-sm">Exportar PDF</a>
        <a asp-action="ExportarExcel" asp-route-reporte="Ejecutivo" class="btn btn-outline-success btn-sm">Exportar Excel</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</div>

<div class="row g-3">
@foreach (var item in new[] {
    ("Equipos disponibles", Model.EquiposDisponibles), ("Equipos asignados", Model.EquiposAsignados), ("Equipos en reparacion", Model.EquiposEnReparacion),
    ("Equipos dados de baja", Model.EquiposDadosDeBaja), ("Insumos registrados", Model.InsumosRegistrados), ("Entradas del mes", Model.EntradasMes),
    ("Salidas del mes", Model.SalidasMes), ("Impresiones pendientes", Model.ImpresionesPendientes), ("Impresiones en proceso", Model.ImpresionesEnProceso),
    ("Impresiones entregadas", Model.ImpresionesEntregadas), ("Impresiones rechazadas", Model.ImpresionesRechazadas) })
{
    <div class="col-md-6 col-xl-3">
        <div class="metric-card">
            <span>@item.Item1</span>
            <strong>@item.Item2</strong>
            <i class="bi bi-bar-chart"></i>
        </div>
    </div>
}
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-6">
        <div class="content-card chart-card">
            <h3 class="h5">Tecnologias por estado</h3>
            <canvas id="tecnologiasChart"></canvas>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="content-card chart-card">
            <h3 class="h5">Impresiones por estado</h3>
            <canvas id="impresionesChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const tecnologias = @Html.Raw(tecnologiasJson);
        const impresiones = @Html.Raw(impresionesJson);
        const colors = ['#0B3D91', '#D4AF37', '#6B7280', '#dc3545'];
        const makeChart = (id, data) => new Chart(document.getElementById(id), {
            type: 'doughnut',
            data: { labels: data.map(x => x.Label), datasets: [{ data: data.map(x => x.Value), backgroundColor: colors }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });
        makeChart('tecnologiasChart', tecnologias);
        makeChart('impresionesChart', impresiones);
    </script>
}
