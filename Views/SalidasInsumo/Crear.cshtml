@model SistemaEscolarWeb.ViewModels.CrearSalidaInsumoViewModel
@{
    ViewData["Title"] = "Registrar salida de insumo";
}

<div class="page-heading">
    <div>
        <h2>Registrar salida de insumo</h2>
        <p>La cantidad solicitada descuenta el stock actual del insumo.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</div>

<div class="content-card">
    <form asp-action="Crear" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="IdInsumo" class="form-label">Insumo</label>
                <select asp-for="IdInsumo" asp-items="Model.Insumos" class="form-select">
                    <option value="">Seleccione un insumo</option>
                </select>
                <span asp-validation-for="IdInsumo" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="IdDependencia" class="form-label">Dependencia</label>
                <select asp-for="IdDependencia" asp-items="Model.Dependencias" class="form-select">
                    <option value="">Seleccione una dependencia</option>
                </select>
                <span asp-validation-for="IdDependencia" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="RutPersonal" class="form-label">Personal responsable</label>
                <select asp-for="RutPersonal" asp-items="Model.Personal" class="form-select">
                    <option value="">Seleccione una persona</option>
                </select>
                <span asp-validation-for="RutPersonal" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="FechaSalida" class="form-label">Fecha de salida</label>
                <input asp-for="FechaSalida" type="date" class="form-control" />
                <span asp-validation-for="FechaSalida" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Cantidad" class="form-label">Cantidad</label>
                <input asp-for="Cantidad" type="number" min="1" max="100000" class="form-control" />
                <span asp-validation-for="Cantidad" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar salida</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
