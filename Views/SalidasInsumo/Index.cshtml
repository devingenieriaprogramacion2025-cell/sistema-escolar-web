@model SistemaEscolarWeb.ViewModels.ListadoPaginadoViewModel<SistemaEscolarWeb.DTOs.SalidaInsumoDto>
@{
    ViewData["Title"] = "Salidas de insumos";
    var puedeGestionar = User.HasPermission("insumos.gestionar", "Editar insumos");
}

<div class="page-heading">
    <div>
        <h2>Salidas de insumos</h2>
        <p>Historial de entregas o salidas de stock.</p>
    </div>
    @if (puedeGestionar)
    {
        <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Nueva salida</a>
    }
</div>

<div class="content-card">
    @if (!Model.Items.Any())
    {
        <div class="empty-state compact">
            <i class="bi bi-box-arrow-up-right"></i>
            <h3>No hay salidas registradas</h3>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th><a class="table-sort-link" asp-route-ordenar="insumo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "insumo")">Insumo <i class="bi @ListadoVista.IconoOrden(Model, "insumo")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="dependencia" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "dependencia")">Dependencia <i class="bi @ListadoVista.IconoOrden(Model, "dependencia")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="responsable" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "responsable")">Personal responsable <i class="bi @ListadoVista.IconoOrden(Model, "responsable")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="fecha" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "fecha")">Fecha salida <i class="bi @ListadoVista.IconoOrden(Model, "fecha")"></i></a></th>
                        <th><a class="table-sort-link" asp-route-ordenar="cantidad" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "cantidad")">Cantidad <i class="bi @ListadoVista.IconoOrden(Model, "cantidad")"></i></a></th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><strong>@item.Insumo</strong></td>
                        <td>@item.Dependencia</td>
                        <td>@item.Responsable</td>
                        <td>@item.FechaSalida.ToString("dd/MM/yyyy")</td>
                        <td>@item.Cantidad</td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-id="@item.IdSalidaInsumo" class="btn btn-outline-secondary btn-sm">Ver</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <partial name="_Paginacion" model="Model" />
    }
</div>
