@model SistemaEscolarWeb.ViewModels.CrearProveedorViewModel
@{
    var esEdicion = Model.IdProveedor.HasValue;
}

<div class="content-card">
    <form asp-action="@(esEdicion ? "Editar" : "Crear")" method="post">
        @Html.AntiForgeryToken()
        @if (esEdicion)
        {
            <input asp-for="IdProveedor" type="hidden" />
        }
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="NombreProveedor" class="form-label"></label>
                <input asp-for="NombreProveedor" class="form-control" maxlength="160" />
                <span asp-validation-for="NombreProveedor" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="RutProveedor" class="form-label"></label>
                <input asp-for="RutProveedor" class="form-control" maxlength="12" inputmode="text" autocomplete="off" placeholder="12.345.678-5" data-rut-chileno />
                <span asp-validation-for="RutProveedor" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Correo" class="form-label"></label>
                <input asp-for="Correo" class="form-control" maxlength="160" />
                <span asp-validation-for="Correo" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Telefono" class="form-label"></label>
                <input asp-for="Telefono" type="tel" class="form-control" maxlength="12" inputmode="tel" autocomplete="tel" placeholder="+56935315783" data-telefono-chileno />
                <span asp-validation-for="Telefono" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
