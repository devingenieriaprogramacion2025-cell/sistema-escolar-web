@model SistemaEscolarWeb.ViewModels.CrearProveedorViewModel
@{
    ViewData["Title"] = "Crear proveedor";
}

<div class="page-heading">
    <div>
        <h2>Crear proveedor</h2>
        <p>Registre un proveedor para reutilizarlo en entradas de insumos y tecnologia.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
</div>

<partial name="_FormularioProveedor" model="Model" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/personal-form.js" asp-append-version="true"></script>
}
