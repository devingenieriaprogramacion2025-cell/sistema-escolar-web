@model SistemaEscolarWeb.Models.Proveedor
@{
    ViewData["Title"] = "Detalle proveedor";
}

<div class="page-heading">
    <div>
        <h2>@Model.NombreProveedor</h2>
        <p>Detalle del proveedor registrado.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Editar" asp-route-id="@Model.IdProveedor" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</div>

<div class="content-card">
    <dl class="row mb-0">
        <dt class="col-md-3">Nombre proveedor</dt>
        <dd class="col-md-9">@Model.NombreProveedor</dd>
        <dt class="col-md-3">RUT proveedor</dt>
        <dd class="col-md-9">@Model.RutProveedor</dd>
        <dt class="col-md-3">Correo</dt>
        <dd class="col-md-9">@(Model.Correo ?? "-")</dd>
        <dt class="col-md-3">Telefono</dt>
        <dd class="col-md-9">@(Model.Telefono ?? "-")</dd>
    </dl>
</div>
