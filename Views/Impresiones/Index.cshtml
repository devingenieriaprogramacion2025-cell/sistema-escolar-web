@model SistemaEscolarWeb.ViewModels.ListadoPaginadoViewModel<SistemaEscolarWeb.DTOs.ImpresionDto>
@{
    ViewData["Title"] = "Impresiones";
    var busqueda = ViewBag.Busqueda as string;
    var puedeSolicitar = User.HasPermission("impresiones.solicitar", "Solicitar impresiones");
    var puedeGestionar = User.HasPermission("impresiones.gestionar", "Aprobar impresiones");
}
@functions {
    string BadgeClass(string estado) => estado switch
    {
        "Pendiente" => "text-bg-warning",
        "En Proceso" => "text-bg-primary",
        "Entregada" => "text-bg-success",
        "Rechazada" => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    bool EsArchivoCargado(string? archivo) =>
        !string.IsNullOrWhiteSpace(archivo) &&
        archivo.StartsWith("uploads/impresiones/", StringComparison.OrdinalIgnoreCase);

    string NombreArchivo(string archivo)
    {
        var nombre = System.IO.Path.GetFileName(archivo);
        var partes = nombre.Split('-', 3);
        return partes.Length == 3 ? partes[2] : nombre;
    }
}

<div class="page-heading">
    <div>
        <h2>Impresiones</h2>
        <p>Solicitudes de entrada, proceso y entrega de material impreso.</p>
    </div>
    @if (puedeSolicitar)
    {
        <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Nueva solicitud</a>
    }
</div>

<div class="content-card mb-3">
    <form asp-action="Index" method="get" class="row g-2 align-items-end">
        <div class="col-md-8">
            <label class="form-label">Buscar</label>
            <input name="busqueda" value="@busqueda" class="form-control" placeholder="Solicitante, archivo o estado..." />
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i> Buscar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Limpiar</a>
        </div>
    </form>
</div>

<div class="content-card">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="solicitante" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "solicitante")">Solicitante <i class="bi @ListadoVista.IconoOrden(Model, "solicitante")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="archivo" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "archivo")">Archivo <i class="bi @ListadoVista.IconoOrden(Model, "archivo")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="paginas" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "paginas")">Paginas <i class="bi @ListadoVista.IconoOrden(Model, "paginas")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="copias" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "copias")">Copias <i class="bi @ListadoVista.IconoOrden(Model, "copias")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="total" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "total")">Total <i class="bi @ListadoVista.IconoOrden(Model, "total")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="opciones" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "opciones")">Opciones <i class="bi @ListadoVista.IconoOrden(Model, "opciones")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="solicitud" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "solicitud")">Solicitud <i class="bi @ListadoVista.IconoOrden(Model, "solicitud")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="entrega" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "entrega")">Entrega requerida <i class="bi @ListadoVista.IconoOrden(Model, "entrega")"></i></a></th>
                    <th><a class="table-sort-link" asp-route-busqueda="@busqueda" asp-route-ordenar="estado" asp-route-direccion="@ListadoVista.ProximaDireccion(Model, "estado")">Estado <i class="bi @ListadoVista.IconoOrden(Model, "estado")"></i></a></th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.NombrePersonal</strong><div class="small text-muted">@item.RutPersonal</div></td>
                    <td>
                        @if (EsArchivoCargado(item.Archivo))
                        {
                            <a asp-action="Archivo" asp-route-id="@item.IdSolicitudImpresion" class="link-primary text-decoration-none">
                                <i class="bi bi-paperclip me-1"></i>@NombreArchivo(item.Archivo!)
                            </a>
                        }
                        else
                        {
                            @(item.Archivo ?? "Sin archivo")
                        }
                        <div class="small text-muted" style="white-space: pre-line">@item.Detalle</div>
                    </td>
                    <td>@item.CantidadPaginas</td>
                    <td>@item.CantidadCopias</td>
                    <td>@item.TotalImpresiones</td>
                    <td>@item.Color / @(item.DobleCara ? "Doble cara" : "Una cara")</td>
                    <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                    <td>@(item.FechaEntrega?.ToString("dd/MM/yyyy") ?? "Sin fecha")</td>
                    <td><span class="badge @BadgeClass(item.Estado)">@item.Estado</span></td>
                    <td class="text-end">
                        <div class="actions-cell">
                            @if (puedeGestionar && item.Estado == "Pendiente")
                            {
                                <button class="btn btn-sm btn-outline-primary"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#comentarioAccionModal"
                                        data-action-url="@Url.Action("EnProceso", "Impresiones", new { id = item.IdSolicitudImpresion })"
                                        data-action-title="Aceptar solicitud"
                                        data-action-button="Aceptar"
                                        data-action-button-class="btn-primary">
                                    Aceptar
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#comentarioAccionModal"
                                        data-action-url="@Url.Action("Rechazar", "Impresiones", new { id = item.IdSolicitudImpresion })"
                                        data-action-title="Rechazar solicitud"
                                        data-action-button="Rechazar"
                                        data-action-button-class="btn-danger">
                                    Rechazar
                                </button>
                            }
                            @if (puedeGestionar && item.Estado != "Entregada" && item.Estado != "Rechazada")
                            {
                                <button class="btn btn-sm btn-outline-success"
                                        type="button"
                                        data-bs-toggle="modal"
                                        data-bs-target="#comentarioAccionModal"
                                        data-action-url="@Url.Action("Entregar", "Impresiones", new { id = item.IdSolicitudImpresion })"
                                        data-action-title="Entregar solicitud"
                                        data-action-button="Entregar"
                                        data-action-button-class="btn-success">
                                    Entregar
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <partial name="_Paginacion" model="Model" />
</div>

<div class="modal fade" id="comentarioAccionModal" tabindex="-1" aria-labelledby="comentarioAccionTitulo" aria-hidden="true">
    <div class="modal-dialog">
        <form id="comentarioAccionForm" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="comentarioAccionTitulo">Registrar accion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <label for="comentarioAccion" class="form-label">Comentario</label>
                <textarea id="comentarioAccion"
                          name="comentario"
                          class="form-control"
                          rows="4"
                          maxlength="500"
                          required
                          placeholder="Ingrese el comentario de la accion realizada"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" id="comentarioAccionSubmit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('comentarioAccionModal');
            const form = document.getElementById('comentarioAccionForm');
            const title = document.getElementById('comentarioAccionTitulo');
            const submit = document.getElementById('comentarioAccionSubmit');
            const comentario = document.getElementById('comentarioAccion');

            modal?.addEventListener('show.bs.modal', (event) => {
                const button = event.relatedTarget;
                if (!button) return;

                form.action = button.dataset.actionUrl ?? '';
                title.textContent = button.dataset.actionTitle ?? 'Registrar accion';
                submit.textContent = button.dataset.actionButton ?? 'Guardar';
                submit.className = `btn ${button.dataset.actionButtonClass ?? 'btn-primary'}`;
                comentario.value = '';
            });

            modal?.addEventListener('shown.bs.modal', () => comentario.focus());
        })();
    </script>
}
