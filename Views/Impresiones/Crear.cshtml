@model SistemaEscolarWeb.ViewModels.CrearImpresionViewModel
@{
    ViewData["Title"] = "Nueva impresion";
}

<div class="page-heading">
    <div>
        <h2>Nueva solicitud de impresion</h2>
        <p>Registre material para impresion y posterior entrega.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
</div>

<div class="content-card">
    <form asp-action="Crear" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="RutPersonal" class="form-label"></label>
                <select asp-for="RutPersonal" asp-items="Model.PersonalDisponible" class="form-select">
                    <option value="">Seleccione solicitante</option>
                </select>
                <span asp-validation-for="RutPersonal" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="CantidadPaginas" class="form-label"></label>
                <input asp-for="CantidadPaginas" type="number" class="form-control" min="1" max="9999" />
                <span asp-validation-for="CantidadPaginas" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="CantidadCopias" class="form-label"></label>
                <input asp-for="CantidadCopias" type="number" class="form-control" min="1" max="9999" />
                <span asp-validation-for="CantidadCopias" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Color" class="form-label"></label>
                <select asp-for="Color" asp-items="Model.Colores" class="form-select"></select>
                <span asp-validation-for="Color" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Total a imprimir</label>
                <div class="form-control bg-light" id="totalImpresiones">@Model.TotalImpresiones paginas</div>
                <div class="form-text" id="dobleCaraTexto">El total corresponde a paginas impresas.</div>
            </div>
            <div class="col-md-6">
                <label asp-for="Archivo" class="form-label"></label>
                <input asp-for="Archivo" type="file" class="form-control" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.rtf,.odt,.ods,.odp,.jpg,.jpeg,.png" required />
                <div class="form-text">Formatos permitidos: PDF, Office, texto e imagenes. Maximo 20 MB.</div>
                <span asp-validation-for="Archivo" class="text-danger small"></span>
            </div>
            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check form-switch">
                    <input asp-for="DobleCara" class="form-check-input" />
                    <label asp-for="DobleCara" class="form-check-label"></label>
                </div>
            </div>
            <div class="col-12">
                <label asp-for="Observacion" class="form-label"></label>
                <textarea asp-for="Observacion" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Observacion" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" type="submit"><i class="bi bi-save me-1"></i> Guardar</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const paginas = document.getElementById('CantidadPaginas');
            const copias = document.getElementById('CantidadCopias');
            const dobleCara = document.getElementById('DobleCara');
            const total = document.getElementById('totalImpresiones');
            const ayuda = document.getElementById('dobleCaraTexto');

            function valor(input) {
                const numero = parseInt(input.value, 10);
                return Number.isFinite(numero) && numero > 0 ? numero : 0;
            }

            function actualizarTotal() {
                const totalPaginas = valor(paginas) * valor(copias);
                total.textContent = `${totalPaginas} paginas`;
                ayuda.textContent = dobleCara.checked
                    ? 'Doble cara puede requerir menos hojas fisicas; el total mantiene paginas impresas.'
                    : 'El total corresponde a paginas impresas.';
            }

            paginas.addEventListener('input', actualizarTotal);
            copias.addEventListener('input', actualizarTotal);
            dobleCara.addEventListener('change', actualizarTotal);
            actualizarTotal();
        })();
    </script>
}
