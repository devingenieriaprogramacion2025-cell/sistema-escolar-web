                        N'ź', N'N'),
                    N'LIBRERIA', N'BIBLIOTECA'),
                N'ENCARGADO TECNOLOGIA', N'ENCARGADA TECNOLOGIA'),
            N'  ', N' ')
        )) PERSISTED;
END

