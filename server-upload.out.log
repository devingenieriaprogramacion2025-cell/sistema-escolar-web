      IF COL_LENGTH(N'Rol', N'nombre_rol_normalizado') IS NULL
BEGIN
    ALTER TABLE [Rol]
    ADD [nombre_rol_normalizado] AS
        LTRIM(RTRIM(
            REPLACE(
                REPLACE(
                    REPLACE(
                        REPLACE(
                            REPLACE(
                                REPLACE(
                                    REPLACE(
                                        REPLACE(
                                            REPLACE(
                                                REPLACE(UPPER([nombre_rol]), N'Ą', N'A'),
